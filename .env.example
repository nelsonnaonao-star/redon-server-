# ─── Supabase ──────────────────────────────────────────────────────────
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_KEY="your-service-role-key"

# ─── Supabase JWT Secret ───────────────────────────────────────────────
# REQUIRED for auth middleware. Get from: Supabase Dashboard → Settings → API → JWT Secret
# SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# ─── Firebase Push Notifications ──────────────────────────────────────
VITE_FIREBASE_API_KEY="your-api-key"
VITE_FIREBASE_PROJECT_ID="red-on-7e788"
VITE_FIREBASE_SENDER_ID="988299578716"
VITE_FIREBASE_APP_ID="1:988299578716:web:your-app-id"
VITE_FIREBASE_VAPID_KEY="your-vapid-public-key"
FIREBASE_PRIVATE_VAPID_KEY="your-vapid-private-key"

# ─── Server ───────────────────────────────────────────────────────────
PORT=5000

# REQUIRED — the deployed Express server URL (Render, Railway, Fly.io, etc.)
# All FCM pushes, TURN credentials, and SMS recovery go here.
# VITE_SERVER_URL=https://your-app.onrender.com

# ─── WebRTC TURN (choose ONE method) ─────────────────────────────────
# Method A: Metered.ca REST API (dynamic credentials, recommended)
# METERED_API_KEY="your_metered_api_key"
# Method B: Static TURN credentials
# VITE_TURN_URL="turn:turn.metered.ca:80"
# VITE_TURN_USERNAME="your_username"
# VITE_TURN_CREDENTIAL="your_password"

# ─── FCM Webhook Secret ──────────────────────────────────────────────
# REQUIRED if using Supabase Database Webhook for push notifications.
# Must match the secret configured in Supabase Dashboard → Database → Webhooks.
# The server verifies this in the x-fcm-secret header.
# FCM_WEBHOOK_SECRET="your-random-secret"

# ─── CORS (server-side) ──────────────────────────────────────────────
# CORS_ORIGIN="https://your-frontend.vercel.app"
# CLIENT_ORIGIN="https://your-frontend.vercel.app"

# ─── Firebase Service Account ─────────────────────────────────────────
# Paste the full Firebase Admin JSON as a single-line string.
# In .env: FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Never commit the JSON file to git — use .env instead.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
